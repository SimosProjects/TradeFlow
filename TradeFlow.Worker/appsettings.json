{
  "ConnectionStrings": {
    "TradeFlow": "Host=localhost;Database=tradeflow;Username=tradeflow_user;Password=tradeflow_dev"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "XTrades": {
    "PageSize": 10,
    "DateSpec": "Today",
    "OrderBy": "TimeOfEntryAlertEpoch desc"
  },
  "RiskEngine": {
    "MinXScore": 60,
    "ApprovedTraders": [
      "yoyomun",
      "Fibonaccizer",
      "Atlas"
    ],
    "AllowLotto": false
  },
  "Polling": {
    "IntervalSeconds": 30
  }
}
